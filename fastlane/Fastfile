# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do

  # Override in CI when needed:
  # IOS_SIMULATOR_DEVICE="iPhone 17 Pro"
  # IOS_SIMULATOR_OS="26.5"
  simulator_device = ENV.fetch("IOS_SIMULATOR_DEVICE", "iPhone 17")
  simulator_os = ENV.fetch("IOS_SIMULATOR_OS", "latest")
  simulator_destination =
    "platform=iOS Simulator,name=#{simulator_device},OS=#{simulator_os}"

  desc "Fix lint issues"
  lane :lint_fix do
    sh "swiftlint lint --fix --config ../.swiftlint.yml --quiet ../"
  end
  
  desc "Code coverage"
  lane :code_coverage do
    
    params = {
      package_path: '.',
      scheme: 'OpenID4VP',
      destination: simulator_destination,
      output_directory: "xcov_output",
      result_bundle: true,
      parallel_testing: false,
      xcodebuild_formatter: "xcbeautify",
      xcargs: ENV['CI'] ? "-skipPackagePluginValidation" : nil
    }

    run_tests(params)

    xcov(
      scheme: "OpenID4VP",
      output_directory: "xcov_output",
      is_swift_package: true,
      minimum_coverage_percentage: 60.0
    )
    if ENV['CI'] != 'true'
      sh 'open ../xcov_output/index.html'
    end
  end

  desc "Run unit tests"
  lane :tests do
    params = {
      package_path: '.',
      scheme: 'OpenID4VP',
      destination: simulator_destination,
      result_bundle: true
    }

    if ENV['CI'] 
      params[:xcargs] = "-skipPackagePluginValidation"
    end

    run_tests(params)
  end

  desc "Builds the package"
  lane :just_build do
    xcodebuild(
      scheme: "OpenID4VP",
      destination: simulator_destination,
      xcargs: "-skipPackagePluginValidation -disableAutomaticPackageResolution"
    )
  end

  before_all do
    FileUtils.remove_dir '../xcov_output', true

    UI.message("Xcode: #{sh('xcodebuild -version', log: false).strip}")
    UI.message("Simulator destination: #{simulator_destination}")

  end

end
